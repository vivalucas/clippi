<Window
    x:Class="Clippi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Uid="MainWindow"
    Title="Clippi">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Clippi"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Text="{x:Bind ViewModel.GpuEncoder, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="12"/>
        </Grid>

        <!-- Drop Area / File Info -->
        <Grid Grid.Row="1" Height="200" Margin="0,0,0,16">
            <!-- Drop Area (shown when no file) -->
            <Border x:Name="DropArea"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="40"
                    AllowDrop="True"
                    Drop="OnFileDrop"
                    DragOver="OnDragOver"
                    Visibility="{x:Bind ConvertBoolToVisibility(ViewModel.HasNoFile), Mode=OneWay}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Tapped="OnSelectFileTapped">
                    <FontIcon Glyph="&#xE710;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock x:Uid="DropPrimaryText"
                               Text="拖拽视频文件到这里"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Uid="DropSecondaryText"
                               Text="或点击选择文件"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- File Info (shown when file loaded) -->
            <Grid x:Name="FileInfoGrid"
                  Visibility="{x:Bind ConvertBoolToVisibility(ViewModel.HasFile), Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <FontIcon Glyph="&#xE714;" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.FileName, Mode=OneWay}"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                </StackPanel>

                <Border Grid.Row="1" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                            <FontIcon Glyph="&#xE711;" FontSize="14"/>
                            <TextBlock x:Uid="ResolutionLabel" Text="分辨率"/>
                            <TextBlock Text="{x:Bind FormatResolution(ViewModel.Width, ViewModel.Height), Mode=OneWay}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                            <FontIcon Glyph="&#xE712;" FontSize="14"/>
                            <TextBlock x:Uid="DurationLabel" Text="时长"/>
                            <TextBlock Text="{x:Bind FormatDuration(ViewModel.Duration), Mode=OneWay}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE713;" FontSize="14"/>
                            <TextBlock x:Uid="CodecLabel" Text="编码"/>
                            <TextBlock Text="{x:Bind ViewModel.Codec, Mode=OneWay}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE715;" FontSize="14"/>
                            <TextBlock x:Uid="FrameRateLabel" Text="帧率"/>
                            <TextBlock Text="{x:Bind FormatFrameRate(ViewModel.FrameRate), Mode=OneWay}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Operation Selector -->
        <RadioButtons x:Uid="OperationSelector" x:Name="OperationSelector" Grid.Row="2" Header="操作" SelectedIndex="0"
                      SelectionChanged="OnOperationChanged">
            <RadioButton x:Uid="TrimOperation" Content="裁剪"/>
            <RadioButton x:Uid="ConvertOperation" Content="转换格式"/>
            <RadioButton x:Uid="ScaleOperation" Content="缩放"/>
            <RadioButton x:Uid="ExtractAudioOperation" Content="提取音频"/>
            <RadioButton x:Uid="RemoveAudioOperation" Content="去除音频"/>
        </RadioButtons>

        <!-- Operation Controls -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <!-- Trim Controls -->
            <StackPanel x:Name="TrimPanel" Visibility="Visible">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <NumberBox x:Uid="TrimStartBox" Grid.Column="0" Header="开始时间 (秒)"
                               Value="{x:Bind ViewModel.StartTime, Mode=TwoWay}"
                               Minimum="0" SpinButtonPlacementMode="Compact"/>

                    <TextBlock x:Uid="TrimRangeText" Grid.Column="1" Text="至" VerticalAlignment="Bottom" Margin="8,0,8,8"/>

                    <NumberBox x:Uid="TrimEndBox" Grid.Column="2" Header="结束时间 (秒)"
                               Value="{x:Bind ViewModel.EndTime, Mode=TwoWay}"
                               Minimum="0" SpinButtonPlacementMode="Compact"/>

                    <ToggleSwitch x:Uid="FastModeSwitch" Grid.Column="4" Header="快速模式"
                                  IsOn="{x:Bind ViewModel.FastMode, Mode=TwoWay}"
                                  OnContent="不重编码" OffContent="精确裁剪"
                                  VerticalAlignment="Bottom" Margin="16,0,0,0"/>
                </Grid>
            </StackPanel>

            <!-- Format Controls -->
            <StackPanel x:Name="FormatPanel" Visibility="Collapsed">
                <TextBlock x:Uid="OutputFormatLabel" Text="输出格式" Margin="0,0,0,8"/>
                <RadioButtons SelectedIndex="0" SelectionChanged="OnFormatChanged">
                    <RadioButton Content="MP4"/>
                    <RadioButton Content="MKV"/>
                    <RadioButton Content="MOV"/>
                    <RadioButton Content="WebM"/>
                </RadioButtons>
            </StackPanel>

            <!-- Scale Controls -->
            <StackPanel x:Name="ScalePanel" Visibility="Collapsed">
                <TextBlock x:Uid="TargetResolutionLabel" Text="目标分辨率" Margin="0,0,0,8"/>
                <RadioButtons SelectedIndex="1" SelectionChanged="OnResolutionChanged">
                    <RadioButton Content="4K (3840x2160)"/>
                    <RadioButton Content="1080p (1920x1080)"/>
                    <RadioButton Content="720p (1280x720)"/>
                    <RadioButton Content="480p (854x480)"/>
                </RadioButtons>
            </StackPanel>

            <!-- Audio Controls -->
            <StackPanel x:Name="AudioPanel" Visibility="Collapsed">
                <TextBlock x:Uid="AudioFormatLabel" Text="音频格式" Margin="0,0,0,8"/>
                <RadioButtons SelectedIndex="0" SelectionChanged="OnAudioFormatChanged">
                    <RadioButton Content="MP3"/>
                    <RadioButton Content="AAC"/>
                    <RadioButton Content="WAV"/>
                </RadioButtons>
            </StackPanel>

            <!-- Remove Audio Info -->
            <TextBlock x:Uid="RemoveAudioText" x:Name="RemoveAudioText" Visibility="Collapsed"
                       Text="将移除视频中的所有音频轨道"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <!-- Output Path -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Uid="OutputPathBox" x:Name="OutputPathBox" Grid.Column="0" Header="输出路径"
                     Text="{x:Bind ViewModel.OutputPath, Mode=TwoWay}"/>

            <Button x:Uid="ChooseOutputButton" x:Name="ChooseOutputButton" Grid.Column="1" Content="选择..." Margin="8,24,0,0"
                    Click="OnSelectOutputPath"/>
        </Grid>

        <!-- Status -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top" Margin="0,12,0,0">
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="WrapWholeWords"
                       VerticalAlignment="Center"/>
            <Button x:Uid="CopyErrorDetailsButton"
                    Content="复制详情"
                    Click="OnCopyErrorDetailsClick"
                    Visibility="{x:Bind ConvertBoolToVisibility(ViewModel.HasErrorDetails), Mode=OneWay}"/>
        </StackPanel>

        <!-- Progress or Actions -->
        <Grid Grid.Row="6" Margin="0,16,0,0">
            <!-- Progress -->
            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed">
                <ProgressBar Value="{x:Bind ViewModel.Progress, Mode=OneWay}" Maximum="100"/>
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <Button x:Uid="CancelButton" Content="取消" HorizontalAlignment="Center" Margin="0,8,0,0"
                        Click="OnCancelClick" Style="{StaticResource AccentButtonStyle}"/>
            </StackPanel>

            <!-- Start Button -->
            <Button x:Uid="StartButton" x:Name="StartButton" Content="开始处理"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Center"
                    Click="OnStartClick"
                    Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
